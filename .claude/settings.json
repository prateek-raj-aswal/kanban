{
  "permissions": {
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "D:\\Personal\\Software Development\\Claude-workspace\\Personal",
      "D:\\Personal\\Software Development\\Claude-workspace\\Agents"
    ],
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash",
      "Glob",
      "Grep",
      "WebFetch",
      "Bash(cd **)",
      "Bash(find **)",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Glob(**)",
      "Grep(**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/log-event.ps1"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/log-usage.ps1"
          }
        ]
      }
    ]
  }
}
