# ─── Claude runtime state ────────────────────────────────────────────
# Regenerated per project — do not commit
.claude/memory/kanban.json
.claude/memory/requirements.md
.claude/memory/plan.json
.claude/memory/delivery.md
.claude/memory/events.jsonl

# Architecture output — regenerated per project, keep dir
.claude/memory/architecture/*
!.claude/memory/architecture/.gitkeep

# Per-story working state — regenerated per run
.claude/memory/stories/*
!.claude/memory/stories/.gitkeep

# Security findings — regenerated per run
.claude/memory/security/*
!.claude/memory/security/.gitkeep

# Curated knowledge IS committed — no entry here, so they're tracked:
#   .claude/memory/decisions/
#   .claude/memory/patterns/

# Personal Claude settings (per developer)
.claude/settings.local.json

