# Copy to .env and fill in values before running docker compose up

# Database
POSTGRES_DB=kanban
POSTGRES_USER=kanban
POSTGRES_PASSWORD=changeme

# JWT — must be at least 32 characters
JWT_SECRET=change-me-to-a-random-32-plus-char-secret
JWT_EXPIRY_MS=3600000

# Frontend public URLs (used at build time — rebuild frontend container after changing)
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=http://localhost:8080/ws
