# Copy to .env and fill in real values before running docker compose
# NEVER commit .env — it is in .gitignore

# ── Backend / Database ──────────────────────────────────────────────────────
# Variable names must match application.yml exactly.
# For local dev (docker-compose.dev.yml) set DB_HOST=postgres (the compose service name).
# For production set DB_HOST to the EC2 hostname below.
DB_HOST=ec2-35-154-3-162.ap-south-1.compute.amazonaws.com
DB_PORT=5432
DB_NAME=mydb
DB_USER=myuser
DB_PASSWORD=changeme

# ── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-32-plus-char-secret
JWT_EXPIRY_MS=3600000

# ── File uploads ─────────────────────────────────────────────────────────────
# Container-internal path; map to a volume in compose or K8s PVC in production.
APP_UPLOAD_DIR=./uploads

# ── Postgres service (docker-compose.dev.yml local postgres only) ────────────
# These are read by the postgres container; values should match DB_NAME/DB_USER above.
POSTGRES_DB=mydb
POSTGRES_USER=myuser
POSTGRES_PASSWORD=changeme

# ── Frontend build-time URLs ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=http://localhost:8080/ws
NEXT_PUBLIC_AGENT_URL=http://localhost:8001
