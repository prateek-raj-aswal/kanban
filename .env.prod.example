# Production environment template.
# Copy to .env on the EC2 server and fill in real values.
# NEVER commit .env — it is in .gitignore.

# ── Database ──────────────────────────────────────────────────────────────────
# Used by both the postgres service and the backend service in docker-compose.prod.yml
DB_NAME=mydb
DB_USER=myuser
DB_PASSWORD=CHANGE_ME_strong_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_at_least_32_random_characters_here
JWT_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# ── Backup (optional overrides) ───────────────────────────────────────────────
# Container to pg_dump from during migration step
BACKUP_SOURCE_CONTAINER=postgres-db
# Directory to write backup files
BACKUP_DIR=/opt/kanban/backups
